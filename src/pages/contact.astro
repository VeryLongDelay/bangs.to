---
import { SITE_TITLE } from '../config/site';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title={`${SITE_TITLE} Contact`}
  description="Contact form for bangs.to."
  currentPath="/contact"
>
  <section class="card overflow-hidden p-3 sm:p-4">
    <div
      class="rounded-[24px] border border-white/80 bg-white/88 p-3 shadow-[0_20px_44px_rgba(15,39,64,0.08)] dark:border-white/10 dark:bg-[rgba(15,23,42,0.72)]"
    >
      <iframe
        src="https://tally.so/embed/lbVy65?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
        data-tally-src="https://tally.so/embed/lbVy65?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
        loading="lazy"
        width="100%"
        height="379"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title="Contact Bangs.to"
        class="block min-h-[379px] w-full rounded-[18px] bg-transparent"
      ></iframe>
    </div>
  </section>
  <script is:inline>
    var d = document,
      w = 'https://tally.so/widgets/embed.js',
      v = function () {
        'undefined' != typeof Tally
          ? Tally.loadEmbeds()
          : d.querySelectorAll('iframe[data-tally-src]:not([src])').forEach(function (e) {
              e.src = e.dataset.tallySrc;
            });
      };
    if ('undefined' != typeof Tally) v();
    else if (d.querySelector('script[src="' + w + '"]') == null) {
      var s = d.createElement('script');
      s.src = w;
      s.onload = v;
      s.onerror = v;
      d.body.appendChild(s);
    }
  </script>
</SiteLayout>
