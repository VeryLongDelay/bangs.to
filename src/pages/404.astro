---
import { SITE_TITLE } from '../config/site';
import SiteLayout from '../layouts/SiteLayout.astro';

const recoveryLinks = [
  {
    href: '/bangs',
    label: 'Browse bangs',
    description: 'See the full directory and pick a destination.'
  },
  {
    href: '/instructions',
    label: 'Set it up',
    description: 'Install bangs.to as a browser search engine.'
  },
  {
    href: '/stats',
    label: 'View local stats',
    description: 'Inspect what this browser has saved on-device.'
  }
];

const exampleQueries = [
  { href: '/?q=!gh%20react', label: '!gh react' },
  { href: '/?q=!w%20saturn', label: '!w saturn' },
  { href: '/?q=!mdn%20fetch', label: '!mdn fetch' },
  { href: '/?q=browser%20search%20shortcuts', label: 'plain search' }
];
---

<SiteLayout
  title={`${SITE_TITLE} Not Found`}
  description="A recovery page for missing routes on bangs.to."
  currentPath="/404"
>
  <div class="grid gap-4 lg:grid-cols-[minmax(300px,0.78fr)_minmax(0,1fr)]">
    <aside class="card h-fit overflow-hidden p-0">
      <div class="border-b border-white/70 bg-linear-to-br from-primary-50 via-white to-sky-50 px-5 py-5 sm:px-6">
        <p class="text-xs font-700 uppercase tracking-[0.26em] text-primary-700">404</p>
        <h1
          class="mt-3 max-w-[11ch] font-display text-[2.45rem] font-800 leading-[0.94] tracking-[-0.05em] text-text sm:text-[2.95rem]"
        >
          This path does not go anywhere useful
        </h1>
        <p class="mt-4 max-w-[34ch] text-sm leading-7 text-text-secondary">
          The fastest recovery is the search bar above. Type a bang, run a normal search, or jump
          back into the parts of the site that are still live.
        </p>
      </div>

      <div class="grid gap-3 px-5 py-5 sm:px-6">
        <div class="rounded-[20px] bg-bg-soft p-4">
          <p class="text-sm font-700 text-text">Most likely cause</p>
          <p class="mt-2 text-sm leading-6 text-text-secondary">
            The URL is old, mistyped, or points to a page that no longer exists.
          </p>
        </div>
        <div class="rounded-[20px] bg-bg-soft p-4">
          <p class="text-sm font-700 text-text">Best next move</p>
          <p class="mt-2 text-sm leading-6 text-text-secondary">
            Search from here instead of hunting through navigation. bangs.to is built for quick
            reroutes, not dead ends.
          </p>
        </div>
      </div>
    </aside>

    <div class="grid gap-4">
      <section class="card overflow-hidden p-0">
        <div class="px-5 pt-5 sm:px-6 sm:pt-6">
          <div
            class="inline-flex items-center gap-2 rounded-full border border-white/75 bg-white/86 px-3 py-1 text-xs font-700 uppercase tracking-[0.2em] text-primary-700"
          >
            Recovery paths
            <span class="h-1.5 w-1.5 rounded-full bg-primary-300"></span>
            Nothing got sent anywhere
          </div>
          <h2
            class="mt-4 max-w-[14ch] font-display text-[1.95rem] font-800 leading-[1.02] tracking-[-0.045em] text-text sm:text-[2.35rem]"
          >
            Pick a live route or run another search
          </h2>
          <p class="mt-3 max-w-[62ch] text-sm leading-7 text-text-secondary sm:text-[0.98rem]">
            Missing pages should be quick to recover from. The search field above is still active,
            and these routes cover the most useful next steps.
          </p>
        </div>

        <div class="mt-5 grid gap-px border-t border-white/70 bg-white/70">
          {
            recoveryLinks.map((link) => (
              <a
                href={link.href}
                class="group grid gap-1 bg-bg-secondary px-5 py-4 no-underline transition-colors duration-150 hover:bg-white/92 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center sm:px-6"
              >
                <div>
                  <p class="text-sm font-700 text-text">{link.label}</p>
                  <p class="mt-1 text-sm leading-6 text-text-secondary">{link.description}</p>
                </div>
                <span
                  class="text-sm font-700 text-primary-700 transition-transform duration-200 group-hover:translate-x-0.5"
                >
                  Open
                </span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="card">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-xs font-700 uppercase tracking-[0.24em] text-primary-700">
              Quick searches
            </p>
            <h2 class="section-title mt-2">Retry from a known-good bang</h2>
            <p class="mt-2 max-w-[58ch] text-sm leading-7 text-text-secondary">
              If you landed here from an old bookmark or typo, one of these should get you moving
              again immediately.
            </p>
          </div>
          <a href="/" class="btn inline-flex items-center justify-center rounded-full px-4 py-2 font-700 no-underline">
            Back home
          </a>
        </div>

        <div class="mt-5 flex flex-wrap gap-2.5">
          {
            exampleQueries.map((example) => (
              <a
                href={example.href}
                class="rounded-full border border-white/80 bg-white/88 px-3.5 py-2 text-sm font-600 no-underline shadow-[0_10px_24px_rgba(15,23,42,0.06)] transition-all duration-150 hover:-translate-y-0.5 hover:bg-white"
              >
                {example.label}
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</SiteLayout>
