---
import { SITE_TAGLINE, SITE_TITLE } from '../config/site';
import iconSvg from '../ui/icon.svg?raw';
import ThemeSwitch from './ThemeSwitch.astro';

interface Props {
  currentPath: string;
  settingsHref?: string;
  showSettingsButton?: boolean;
}

const { currentPath, settingsHref = '/#settings', showSettingsButton = false } = Astro.props;

const links = [
  { href: '/', label: 'Home', match: ['/', '/home'] },
  { href: '/bangs', label: '!Bangs', match: ['/bangs'] },
  // { href: '/stats', label: 'Stats', match: ['/stats'] },
  { href: '/instructions', label: 'Instructions', match: ['/instructions'] },
  { href: '/faq', label: 'FAQ', match: ['/faq'] }
];
---

<header
  class="card mb-6 flex flex-col gap-4 px-5 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6"
>
  <div class="flex items-center gap-3">
    <div
      class="group relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-slate-200/80 bg-white/72 p-0.5 shadow-[0_12px_24px_rgba(37,99,235,0.14)] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-[2px] hover:border-primary-300/60 hover:shadow-[0_20px_40px_rgba(37,99,235,0.22)] active:translate-y-0 active:scale-[0.98] dark:border-white/12 dark:bg-[rgba(15,23,42,0.5)] dark:hover:border-white/18 dark:hover:bg-[rgba(15,23,42,0.64)]"
      aria-hidden="true"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
      >
        <div
          class="absolute inset-[-45%] animate-[spin_5s_linear_infinite] bg-[conic-gradient(from_180deg_at_50%_50%,rgba(59,130,246,0)_0deg,rgba(59,130,246,0.26)_120deg,rgba(168,85,247,0.3)_230deg,rgba(59,130,246,0)_360deg)]"
        >
        </div>
      </div>

      <div
        class="pointer-events-none absolute inset-0 translate-x-[-140%] bg-[linear-gradient(110deg,transparent_0%,rgba(255,255,255,0.16)_44%,rgba(255,255,255,0.5)_50%,rgba(255,255,255,0.16)_56%,transparent_100%)] opacity-0 transition-all duration-700 group-hover:translate-x-[140%] group-hover:opacity-100 dark:bg-[linear-gradient(110deg,transparent_0%,rgba(255,255,255,0.05)_44%,rgba(255,255,255,0.16)_50%,rgba(255,255,255,0.05)_56%,transparent_100%)]"
      >
      </div>

      <div
        class="relative z-10 h-full w-full overflow-hidden rounded-[0.95rem] [&_svg]:block [&_svg]:h-full [&_svg]:w-full [&_svg]:transition-transform [&_svg]:duration-500 [&_svg]:ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:[&_svg]:-translate-y-[1px] group-hover:[&_svg]:rotate-[6deg] group-hover:[&_svg]:scale-[1.08]"
        set:html={iconSvg}
      />
    </div>

    <div>
      <p class="font-display text-lg font-700 tracking-tight text-text">{SITE_TITLE}</p>
      <p class="text-sm text-text-secondary">{SITE_TAGLINE}</p>
    </div>
  </div>

  <nav class="flex flex-wrap items-center gap-2 text-sm">
    {
      links.map(link => {
        const active = link.match.includes(currentPath);
        return (
          <a
            href={link.href}
            class={`btn no-underline ${active ? 'border-primary-300 bg-primary-50/80 text-primary-700' : ''}`}
            aria-current={active ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })
    }
    {
      showSettingsButton && (
        <a
          href={settingsHref}
          id="gear-btn"
          class="btn flex items-center gap-2 no-underline"
          aria-label="Open settings"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
          Settings
        </a>
      )
    }
    <ThemeSwitch />
  </nav>
</header>
