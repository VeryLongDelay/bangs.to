---
const examples = [
  { href: "/?q=!gh%20react", label: "!gh react" },
  { href: "/?q=!w%20service%20worker", label: "!w service worker" },
  { href: "/?q=weather%20vancouver", label: "weather vancouver" },
];
---

<section class="card mb-6 overflow-hidden p-0">
  <div
    class="grid gap-5 border-b border-white/70 bg-linear-to-br from-primary-50 via-white to-sky-50 px-5 py-5 sm:px-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(260px,0.9fr)] lg:items-center"
  >
    <div>
      <div
        class="mb-3 inline-flex items-center gap-2 rounded-full bg-white/85 px-3 py-1 text-xs font-700 uppercase tracking-[0.22em] text-primary-700"
      >
        Try a search
        <span class="h-1 w-1 rounded-full bg-primary-300"></span>
        Private flow
      </div>
      <h2
        class="font-display text-[1.9rem] font-700 leading-tight tracking-[-0.04em] text-text sm:text-[2.25rem]"
      >
        Search from any page without losing context.
      </h2>
      <p class="mt-3 max-w-[58ch] text-sm leading-7 text-text-secondary sm:text-[0.98rem]">
        Use a bang to jump to a destination, or type a normal query and let
        your default engine take over. The same <code>?q=</code> flow powers
        browser search engine integration.
      </p>
    </div>

    <div class="rounded-[24px] border border-white/80 bg-white/86 p-4">
      <p class="text-sm font-700 text-text">Quick examples</p>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        {
          examples.map((example) => (
            <a
              href={example.href}
              class="rounded-full border border-primary-100 bg-white/90 px-3 py-1.5 no-underline"
            >
              {example.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="px-5 py-5 sm:px-6">
    <form
      action="/"
      method="get"
      class="rounded-[28px] border border-white/80 bg-white/88 p-3 shadow-[0_18px_40px_rgba(15,39,64,0.08)]"
    >
      <label for="try-query" class="sr-only">Try a search</label>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <input
          type="text"
          id="try-query"
          name="q"
          autocomplete="off"
          spellcheck="false"
          placeholder="Try: !gh react, !w saturn, or plain search"
          aria-label="Try a search"
          class="input-field min-w-0 flex-1"
        />
        <button
          type="submit"
          class="btn-primary w-full sm:w-auto sm:min-w-[7rem]"
        >
          Search
        </button>
      </div>
    </form>
  </div>
</section>
