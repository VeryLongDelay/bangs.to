<label
  class="theme-switch btn px-3 py-2.5"
  data-theme-toggle
  aria-label="Dark mode"
>
  <span class="theme-switch-label text-sm font-600 text-text">Dark mode</span>
  <input
    type="checkbox"
    class="theme-switch-input"
    data-theme-toggle-input
    aria-label="Dark mode"
  />
  <span class="theme-switch-track" aria-hidden="true">
    <span class="theme-switch-thumb"></span>
  </span>
</label>
