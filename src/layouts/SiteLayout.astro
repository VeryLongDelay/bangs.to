---
import SettingsModal from "../components/SettingsModal.astro";
import SiteFooter from "../components/SiteFooter.astro";
import TopBar from "../components/TopBar.astro";
import TrySearch from "../components/TrySearch.astro";
import {
  getCanonicalUrl,
  getSettingsHref,
  OG_DESCRIPTION,
  OG_IMAGE_URL,
  SITE_TAGLINE,
  SITE_TITLE,
  SITE_URL,
} from "../config/site";
import baseJsonLdText from "../ui/assets/site.jsonld?raw";

interface Props {
  currentPath: string;
  description: string;
  title: string;
  pageScript?: "app" | "bangs" | "stats";
  showSettingsButton?: boolean;
  showTrySearch?: boolean;
  registerServiceWorker?: boolean;
  searchEntrypoint?: boolean;
}

const {
  currentPath,
  description,
  title,
  pageScript,
  showSettingsButton = true,
  showTrySearch = true,
  registerServiceWorker = false,
  searchEntrypoint = false,
} = Astro.props;

const tagline = SITE_TAGLINE;
const siteUrl = SITE_URL;
const ogImageUrl = OG_IMAGE_URL;
const ogDescription = OG_DESCRIPTION;
const settingsHref = getSettingsHref(currentPath);
const canonicalUrl = getCanonicalUrl(currentPath);
const baseJsonLd = JSON.parse(baseJsonLdText);
const jsonLd = {
  ...baseJsonLd,
  "@graph": [
    ...baseJsonLd["@graph"],
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      isPartOf: {
        "@id": `${siteUrl}/#website`,
      },
      about: {
        "@id": `${siteUrl}/#app`,
      },
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: ogImageUrl,
      },
      inLanguage: "en-US",
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - {tagline}</title>
    <meta name="description" content={ogDescription}>
    <!-- Search engine meta tags -->
    <meta property="og:site_name" content={`${SITE_TITLE} - ${tagline}`} />
    <meta property="og:locale" content="en_US" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />

    <!-- Meta Tags for social media -->
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={ogDescription}>
    <meta property="og:image" content={ogImageUrl}>
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} - ${tagline}`}>
    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:domain" content={title}>
    <meta property="twitter:url" content={canonicalUrl}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={ogDescription}>
    <meta name="twitter:image" content={ogImageUrl}>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

    <link rel="stylesheet" href="/styles.css" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="search"
      type="application/opensearchdescription+xml"
      title={SITE_TITLE}
      href="/opensearch.xml"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4f8fc" />
    <script is:inline>
      "use strict";
      (() => {
        try {
          const theme = localStorage.getItem("theme");
          if (theme === "dark" || theme === "light") {
            document.documentElement.dataset.theme = theme;
            document.documentElement.style.colorScheme = theme;
          } else {
            document.documentElement.dataset.theme = "dark";
            document.documentElement.style.colorScheme = "dark";
          }
        } catch {
          // ignore storage failures before app boot
          document.documentElement.dataset.theme = "dark";
          document.documentElement.style.colorScheme = "dark";
        }
      })();
    </script>
    <script is:inline>
      "use strict";
      fetch("/opensearch.xml");
    </script>
  </head>
  <body>
    <div
      class="relative min-h-screen px-5 pb-8 pt-5 sm:px-6 sm:pb-10 sm:pt-6 lg:px-8"
    >
      <div
        class="mx-auto flex min-h-[calc(100vh-3rem)] max-w-[1180px] flex-col"
      >
        <TopBar
          currentPath={currentPath}
          settingsHref={settingsHref}
          showSettingsButton={showSettingsButton}
        />
        {showTrySearch && (
          <div class="mb-4 sm:mb-6">
            <TrySearch />
          </div>
        )}
        <main class="flex-1 pb-8">
          <slot />
        </main>
        <SiteFooter />
      </div>
    </div>

    <SettingsModal />
    <slot name="afterBody" />

    <script type="module" src="/theme.js"></script>
    <script type="module" src="/app.js"></script>
    {pageScript && <script type="module" src={`/${pageScript}.js`}></script>}
    {
      registerServiceWorker && (
        <script is:inline define:vars={{ searchEntrypoint }}>
          "use strict";
          if ("serviceWorker" in navigator) {
            const hadController = !!navigator.serviceWorker.controller;
            const hasQuery =
              location.search.startsWith("?q=") ||
              location.search.includes("&q=");
            const query = hasQuery
              ? new URLSearchParams(location.search).get("q")
              : null;

            if (searchEntrypoint && query && !navigator.serviceWorker.controller) {
              navigator.serviceWorker.addEventListener(
                "message",
                (e) => {
                  if (e.data?.url) {
                    location.replace(e.data.url);
                  }
                },
                { once: true }
              );
              navigator.serviceWorker.addEventListener(
                "controllerchange",
                () => {
                  navigator.serviceWorker.controller?.postMessage({
                    type: "redirect",
                    query,
                  });
                },
                { once: true }
              );
            }

            navigator.serviceWorker.register("/sw.js").then((reg) => {
              reg.addEventListener("updatefound", () => {
                const sw = reg.installing;
                if (!sw) {
                  return;
                }
                sw.addEventListener("statechange", () => {
                  if (sw.state === "activated" && hadController) {
                    location.reload();
                  }
                });
              });
            });
          }
        </script>
      )
    }
  </body>
</html>
