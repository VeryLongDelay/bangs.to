{
  "name": "bangs-to",
  "private": true,
  "version": "1.3.4",
  "type": "module",
  "scripts": {
    "codegen": "node --disable-warning=DEP0205 --import tsx/esm scripts/codegen.ts",
    "build": "node --disable-warning=DEP0205 --import tsx/esm scripts/build.ts",
    "build:astro": "astro build --outDir .astro-build",
    "build:sw": "esbuild src/sw/sw.ts --bundle --outfile=dist/sw.js --minify --target=chrome100,firefox100,safari15 --format=esm --define:__CACHE_VERSION__='\"manual\"' --define:__EXTRA_ASSETS__='[]' --define:__IS_DEV__='false'",
    "build:ui": "esbuild src/ui/app.ts --bundle --outfile=dist/app.js --splitting --minify --target=chrome100,firefox100,safari15 --format=esm",
    "build:css": "unocss 'src/**/*.astro' 'src/ui/index.html' 'src/ui/**/*.ts' -o dist/styles.css --minify",
    "dev": "node --disable-warning=DEP0205 --import tsx/esm scripts/dev.ts",
    "start": "node --disable-warning=DEP0205 --import tsx/esm scripts/start.ts",
    "check": "biome check .",
    "fix": "biome check --write .",
    "lint": "pnpm run check",
    "lint:fix": "pnpm run fix",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "profile": "node --disable-warning=DEP0205 --import tsx/esm scripts/profile.ts",
    "clean": "node -e \"import('node:fs').then(({rmSync})=>rmSync('dist',{recursive:true,force:true}))\"",
    "test": "vitest run",
    "test:e2e": "pnpm run build && NODE_OPTIONS=--disable-warning=DEP0205 playwright test",
    "preview": "node --disable-warning=DEP0205 --import tsx/esm scripts/codegen.ts --from-merged && node --disable-warning=DEP0205 --import tsx/esm scripts/build.ts && wrangler pages dev",
    "deploy": "node --disable-warning=DEP0205 --import tsx/esm scripts/codegen.ts --from-merged && node --disable-warning=DEP0205 --import tsx/esm scripts/build.ts && wrangler pages deploy dist"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@minify-html/node": "0.18.1",
    "@playwright/test": "1.59.1",
    "@types/node": "^24.10.1",
    "@unocss/cli": "66.6.8",
    "astro": "6.3.1",
    "esbuild": "^0.27.0",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.20.6",
    "typescript": "6.0.3",
    "unocss": "66.6.8",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "defu": "6.1.7",
    "picomatch": "4.0.4",
    "postcss": "^8.5.14",
    "rollup": "4.60.3",
    "vite": "8.0.11"
  }
}
