{
  "name": "flashbang",
  "private": true,
  "version": "1.3.4",
  "type": "module",
  "scripts": {
    "codegen": "bun scripts/codegen.ts",
    "build": "bun scripts/build.ts",
    "build:astro": "astro build --outDir .astro-build",
    "build:sw": "bun build src/sw/sw.ts --outdir dist --entry-naming sw.js --minify --target browser --format esm",
    "build:ui": "bun build src/ui/app.ts --outdir dist --entry-naming app.js --minify --target browser",
    "build:css": "bunx unocss 'src/**/*.astro' 'src/ui/index.html' 'src/ui/**/*.ts' -o dist/styles.css --minify",
    "dev": "bun scripts/dev.ts",
    "start": "bun scripts/start.ts",
    "check": "biome check",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "fix": "biome check --write",
    "profile": "bun scripts/profile.ts",
    "clean": "bun -e \"import{rmSync}from'fs';rmSync('dist',{recursive:true,force:true})\"",
    "test": "bun test",
    "test:e2e": "bun run build && bunx playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@minify-html/node": "0.18.1",
    "@playwright/test": "1.59.1",
    "@types/bun": "1.3.11",
    "@unocss/cli": "66.6.7",
    "astro": "6.2.1",
    "typescript": "6.0.2",
    "unocss": "66.6.7"
  },
  "dependencies": {
    "defu": "6.1.6",
    "picomatch": "4.0.4",
    "rollup": "4.60.1",
    "vite": "8.0.5"
  }
}
